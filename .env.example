APP_NAME=Poachy
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=UTC
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=redis
# APP_PREVIOUS_KEYS=

PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

# =============================================================================
# DOCKER COMPOSE  (host-side port forwarding & run-as user)
# =============================================================================
APP_PORT=80
FORWARD_DB_PORT=3307
FORWARD_REDIS_PORT=6380
FORWARD_MAILPIT_PORT=1025
FORWARD_MAILPIT_DASHBOARD_PORT=8025
FORWARD_PHPMYADMIN_PORT=8080

# Run-as UID/GID — avoids permission issues on volume-mounted code.
# Set to your host user: id -u  &&  id -g
WWWUSER=1000
WWWGROUP=1000

# =============================================================================
# MULTI-TENANCY
# =============================================================================
# Comma-separated list of domains that serve the central app (not tenants)
CENTRAL_DOMAINS=poachy.test

# Prefix used when creating tenant databases: {prefix}{tenant_id}{suffix}
TENANT_DB_PREFIX=poachy_tenant_
TENANT_DB_SUFFIX=

# =============================================================================
# CENTRAL DATABASE  (shared/admin database)
# =============================================================================
DB_CONNECTION=central
# Docker: use the compose service name. Bare metal: 127.0.0.1
CENTRAL_DB_HOST=mysql
CENTRAL_DB_PORT=3306
CENTRAL_DB_DATABASE=poachy
CENTRAL_DB_USERNAME=root
CENTRAL_DB_PASSWORD=

# =============================================================================
# TENANT DATABASE  (credentials used when creating/connecting tenant DBs)
# The database name is auto-generated from TENANT_DB_PREFIX + tenant_id + TENANT_DB_SUFFIX
# =============================================================================
TENANT_DB_HOST=mysql
TENANT_DB_PORT=3306
TENANT_DB_USERNAME=root
TENANT_DB_PASSWORD=

# Optional: MySQL SSL CA path (for managed cloud databases e.g. PlanetScale, RDS)
# MYSQL_ATTR_SSL_CA=/path/to/ca-cert.pem

# =============================================================================
# INTER-SERVICE API TOKENS
# =============================================================================
# Used by tenant services to call back into the central app
CENTRAL_API_URL=http://localhost
CENTRAL_API_TOKEN=change-me-generate-a-secure-random-token
CENTRAL_API_TIMEOUT=60

# Used by central to call into tenant apps
TENANT_API_TOKEN=change-me-generate-a-secure-random-token

# =============================================================================
# CACHE
# =============================================================================
CACHE_STORE=redis
CACHE_PREFIX=poachy_cache

# =============================================================================
# REDIS  (cache, queues, sessions, and Horizon)
# =============================================================================
REDIS_CLIENT=phpredis
# Docker: use the compose service name. Bare metal: 127.0.0.1
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_USERNAME=
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_HORIZON_DB=2
REDIS_PREFIX=poachy_
# REDIS_URL=redis://username:password@host:6379/db

# Redis connection tuning (optional — leave commented unless needed)
# REDIS_PERSISTENT=false
# REDIS_MAX_RETRIES=3
# REDIS_BACKOFF_ALGORITHM=decorrelated_jitter
# REDIS_BACKOFF_BASE=100
# REDIS_BACKOFF_CAP=1000
# REDIS_CLUSTER=false

# =============================================================================
# SESSION
# =============================================================================
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
# SESSION_TABLE=sessions
# SESSION_CONNECTION=
# SESSION_STORE=
# SESSION_EXPIRE_ON_CLOSE=false
# SESSION_PARTITIONED_COOKIE=false

# =============================================================================
# QUEUE
# =============================================================================
QUEUE_CONNECTION=redis
QUEUE_FAILED_DRIVER=database-uuids

REDIS_QUEUE=default
REDIS_QUEUE_CONNECTION=default
REDIS_QUEUE_RETRY_AFTER=90

# =============================================================================
# BROADCAST / FILESYSTEM
# =============================================================================
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# =============================================================================
# MAIL
# =============================================================================
# Docker: use mailpit (docker compose --profile dev-tools up -d)
# Dashboard at http://localhost:8025
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_SCHEME=null
MAIL_FROM_ADDRESS="hello@poachy.com"
MAIL_FROM_NAME="${APP_NAME}"
# MAIL_EHLO_DOMAIN=
# MAIL_URL=
# MAIL_LOG_CHANNEL=
# MAIL_SENDMAIL_PATH=/usr/sbin/sendmail -bs -i

# --- Postmark (alternative mailer) ---
# MAIL_MAILER=postmark
# POSTMARK_TOKEN=
# POSTMARK_MESSAGE_STREAM_ID=

# --- Resend (alternative mailer) ---
# MAIL_MAILER=resend
# RESEND_KEY=

# =============================================================================
# LOGGING
# =============================================================================
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug
LOG_DEPRECATIONS_CHANNEL=null
LOG_DEPRECATIONS_TRACE=false
# LOG_DAILY_DAYS=14
# LOG_SLACK_WEBHOOK_URL=
# LOG_SLACK_USERNAME=Laravel
# LOG_SLACK_EMOJI=:boom:
# LOG_STDERR_FORMATTER=
# PAPERTRAIL_URL=
# PAPERTRAIL_PORT=

# =============================================================================
# AUTHENTICATION & SANCTUM
# =============================================================================
AUTH_PASSWORD_TIMEOUT=10800
SANCTUM_EXPIRATION=
SANCTUM_TOKEN_PREFIX=

# =============================================================================
# HORIZON  (queue dashboard — /horizon)
# =============================================================================
HORIZON_NAME="${APP_NAME} Horizon"
HORIZON_PATH=horizon
# HORIZON_DOMAIN=
# HORIZON_PREFIX=

# =============================================================================
# AUDIT LOGGING
# =============================================================================
AUDIT_LOGGING_ENABLED=true
AUDIT_ASYNC_ENABLED=false
AUDIT_QUEUE=sync-low

# =============================================================================
# SHIFT MANAGEMENT
# =============================================================================
SHIFT_CASH_VARIANCE_THRESHOLD=100
SHIFT_NO_SHOW_GRACE_PERIOD=30
SHIFT_AUTO_MARK_NO_SHOW=true
SHIFT_LATE_THRESHOLD=15
SHIFT_EARLY_DEPARTURE_THRESHOLD=15
SHIFT_CALCULATE_OVERTIME=true
SHIFT_OVERTIME_RATE=1.5
SHIFT_SEND_REMINDERS=true
SHIFT_REMINDER_HOURS_BEFORE=2
SHIFT_ALLOW_SWAPS=true
SHIFT_SWAP_EXPIRES_HOURS=48
SHIFT_SWAP_REQUIRE_MANAGER=true
SHIFT_PREVENT_OVERLAPPING=true
SHIFT_ALLOW_BACK_TO_BACK=true
SHIFT_MIN_REST_HOURS=0
SHIFT_PREVENT_MULTI_STORE=true
SHIFT_REQUIRE_APPROVAL=false
SHIFT_AUTO_APPROVE_SMALL_VARIANCE=true
SHIFT_PREVENT_SELF_APPROVAL=true
SHIFT_NOTIFY_EMAIL=true
SHIFT_NOTIFY_SMS=false
SHIFT_NOTIFY_IN_APP=true
# SHIFT_RETENTION_YEARS=

# =============================================================================
# AWS  (S3 storage / SES mail / SQS queues — leave blank if not using AWS)
# =============================================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
# AWS_URL=
# AWS_ENDPOINT=

# =============================================================================
# MEMCACHED  (only needed if CACHE_STORE=memcached)
# =============================================================================
MEMCACHED_HOST=127.0.0.1
# MEMCACHED_PORT=11211
# MEMCACHED_USERNAME=
# MEMCACHED_PASSWORD=
# MEMCACHED_PERSISTENT_ID=

# =============================================================================
# SLACK NOTIFICATIONS  (optional)
# =============================================================================
# SLACK_BOT_USER_OAUTH_TOKEN=
# SLACK_BOT_USER_DEFAULT_CHANNEL=

# =============================================================================
# API DOCS  (L5-Swagger — set GENERATE_ALWAYS=false in production)
# =============================================================================
L5_SWAGGER_GENERATE_ALWAYS=false
# L5_SWAGGER_CONST_HOST=http://localhost
# L5_SWAGGER_UI_DARK_MODE=false
# L5_SWAGGER_UI_DOC_EXPANSION=list
# L5_SWAGGER_UI_FILTERS=true
# L5_SWAGGER_UI_PERSIST_AUTHORIZATION=false
# L5_SWAGGER_OPERATIONS_SORT=
# L5_SWAGGER_GENERATE_YAML_COPY=false
# L5_FORMAT_TO_USE_FOR_DOCS=json
# L5_SWAGGER_OPEN_API_SPEC_VERSION=3.0.0

# =============================================================================
# VITE (frontend build)
# =============================================================================
VITE_APP_NAME="${APP_NAME}"
